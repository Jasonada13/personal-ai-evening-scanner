# Copy this file to .env.local for local dev (not committed)
# For production: set as GitHub Secret: DISCORD_WEBHOOK_URL

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Run in paper/educational mode by default
PAPER_MODE=true

# Evening US AI/tech focus (for UK 9-5 trader)
EVENING_WINDOW_UTC=22

# Small focused universe for personal learning
AI_TECH_UNIVERSE=NVDA,AMD,TSLA,PLTR,SMCI,AVGO
